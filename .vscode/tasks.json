{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build Debug Win32",
      "type": "shell",
      "command": "C:\\Program Files\\Microsoft Visual Studio\\18\\Enterprise\\MSBuild\\Current\\Bin\\MSBuild.exe",
      "args": [
        "ErgoActive.sln",
        "/t:Build",
        "/p:Configuration=Debug",
        "/p:Platform=x64",
        "/m",
        "/nologo"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "hide": true,
      "problemMatcher": "$msCompile"
    },
    {
      "label": "Build Debug x64",
      "type": "shell",
      "command": "C:\\Program Files\\Microsoft Visual Studio\\18\\Enterprise\\MSBuild\\Current\\Bin\\MSBuild.exe",
      "args": [
        "ErgoActive.sln",
        "/t:Build",
        "/p:Configuration=Debug",
        "/p:Platform=x64",
        "/m",
        "/nologo"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": "$msCompile"
    }
  ]
}